{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/api/matches/?(?:/__data.json)?$",
			"dest": "/api/matches"
		},
		{
			"src": "^/api/pieces/?(?:/__data.json)?$",
			"dest": "/api/pieces"
		},
		{
			"src": "^/api/pieces/([^/]+?)/images/?(?:/__data.json)?$",
			"dest": "/api/pieces/[id]/images"
		},
		{
			"src": "^/api/upload/?(?:/__data.json)?$",
			"dest": "/api/upload"
		},
		{
			"src": "^/auth/?(?:/__data.json)?$",
			"dest": "/auth"
		},
		{
			"src": "^/auth/callback/?(?:/__data.json)?$",
			"dest": "/auth/callback"
		},
		{
			"src": "^/pieces/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/pieces/[id]"
		},
		{
			"src": "^/upload/?(?:/__data.json)?$",
			"dest": "/upload"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}